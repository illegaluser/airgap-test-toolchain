#!/usr/bin/env bash
# pre-push — 두 가지 일을 한다 (순서 중요):
#
#   [1] playwright-allinone/e2e-test/ 슈트 발사 → 실패 시 push 차단.
#       CI 없음 전제 (github actions 비용 0 정책). pre-commit 보다 빈도 낮은
#       push 시점이 e2e 자동 가드의 유일 슬롯. 설계 근거 +  슬롯 매핑은
#       playwright-allinone/docs/PLAN_E2E_REWRITE.md 참조.
#       시간 예산: < 5분.
#
#   [2] Replay UI 휴대용 자산 stale 검출 + 자동 갱신 (경고만, push 비차단).
#       자산이 .gitignore 라 push 자체에는 안 실리지만, 이 PC 의 replay-ui/
#       폴더가 항상 최신이도록 유지 → 출시 직전 'zip -r' 한 줄로 신뢰할 수
#       있는 반출 zip.
#
# 설치 (개발자 PC 1회):
#   bash playwright-allinone/scripts/install-git-hooks.sh
# 일시 우회:
#   git push --no-verify (긴급 핫픽스 외 금지)

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# ------------------------------------------------------------------------------
# [1] e2e-test/ 발사 — 실패 시 push 차단.
# ------------------------------------------------------------------------------
E2E_DIR="$REPO_ROOT/playwright-allinone/e2e-test"
VENV_PY="${E2E_PYTHON:-$HOME/.dscore.ttc.playwright-agent/venv/bin/python3}"

if [ ! -d "$E2E_DIR" ]; then
  echo "[pre-push] ⚠ e2e-test/ 미존재 — 스킵 (rollback 또는 다른 브랜치)" >&2
elif [ ! -x "$VENV_PY" ]; then
  echo "[pre-push] ⚠ venv python 미존재 — e2e-test/ 스킵 ($VENV_PY)" >&2
  echo "[pre-push]   설정: mac-agent-setup.sh / wsl-agent-setup.sh 로 venv 생성" >&2
else
  echo "[pre-push] e2e-test/ 발사 (pytest, headless)..." >&2
  START=$(date +%s)
  if ( cd "$REPO_ROOT/playwright-allinone" \
       && "$VENV_PY" -m pytest e2e-test -q --tb=short ); then
    ELAPSED=$(( $(date +%s) - START ))
    echo "[pre-push] ✓ e2e-test/ 통과 (${ELAPSED}s)" >&2
  else
    RC=$?
    ELAPSED=$(( $(date +%s) - START ))
    echo "" >&2
    echo "[pre-push] ✗ e2e-test/ 실패 (${ELAPSED}s) — push 차단" >&2
    echo "[pre-push]   우회: git push --no-verify (긴급시만)" >&2
    exit $RC
  fi
fi

# ------------------------------------------------------------------------------
# [2] Replay UI 휴대용 자산 stale 검출 + 자동 갱신 (경고만).
# ------------------------------------------------------------------------------
REPLAYUI_DIR="$REPO_ROOT/playwright-allinone/replay-ui"
BUILD_DIR="$REPO_ROOT/playwright-allinone/replay-ui-portable-build"
STAMP_FILE="$REPLAYUI_DIR/.pack-stamp"

# 자산 source 가 이 repo 에 없으면 (다른 브랜치 등) skip.
[[ -d "$REPLAYUI_DIR" && -d "$BUILD_DIR" ]] || exit 0

# git ls-tree → 자산 source 의 현재 commit 기준 tree SHA.
if command -v sha256sum >/dev/null 2>&1; then
  HASH_CMD="sha256sum"
else
  HASH_CMD="shasum -a 256"
fi
CURRENT_SHA="$(cd "$REPO_ROOT" && git rev-parse \
  HEAD:playwright-allinone/shared \
  HEAD:playwright-allinone/replay-ui/replay_service \
  HEAD:playwright-allinone/replay-ui/monitor \
  HEAD:playwright-allinone/replay-ui-portable-build/templates \
  2>/dev/null | tr -d '\n' | $HASH_CMD | awk '{print $1}')"

if [[ -z "$CURRENT_SHA" ]]; then
  # git ls-tree 실패 — 새 repo 또는 추적 안 됨. skip.
  exit 0
fi

if [[ -f "$STAMP_FILE" ]] && [[ "$(cat "$STAMP_FILE" 2>/dev/null)" == "$CURRENT_SHA" ]]; then
  # 자산 최신 — 그대로 push.
  exit 0
fi

if [[ ! -f "$STAMP_FILE" ]]; then
  echo "[pre-push] Replay UI 휴대용 자산이 아직 채워지지 않았습니다." >&2
else
  echo "[pre-push] Replay UI 휴대용 자산이 stale (source 변경 감지)." >&2
fi
echo "[pre-push] 자동 갱신 시도 중 — 1~2분 소요될 수 있습니다." >&2

OS="$(uname -s)"
PACK_OK=0
case "$OS" in
  Darwin)
    if bash "$BUILD_DIR/pack-macos.sh" --reuse-cache --no-zip >&2; then
      PACK_OK=1
    fi
    ;;
  MINGW*|MSYS*|CYGWIN*)
    if command -v powershell >/dev/null 2>&1; then
      if powershell -NoProfile -ExecutionPolicy Bypass \
         -File "$BUILD_DIR/pack-windows.ps1" -ReuseCache >&2; then
        PACK_OK=1
      fi
    else
      echo "[pre-push] powershell 미발견 — Windows 자산 갱신 스킵." >&2
    fi
    ;;
  Linux)
    echo "[pre-push] Linux 개발 환경 — Linux 용 pack 스크립트 없음. 출시 시점에 Win/Mac 빌드 머신에서 수동 갱신." >&2
    ;;
  *)
    echo "[pre-push] 알 수 없는 OS=$OS — 자산 갱신 스킵." >&2
    ;;
esac

if [[ "$PACK_OK" = "1" ]]; then
  echo "[pre-push] 자산 갱신 완료. push 를 계속 진행합니다." >&2
else
  echo "[pre-push] WARN — 자산 갱신 실패 또는 스킵 (cache 부족·의존성 부재·OS 미지원)." >&2
  echo "[pre-push]        출시 직전에 수동으로 pack-* 한 줄을 실행하세요." >&2
  echo "[pre-push]        push 자체는 자산을 싣지 않으므로 그대로 진행합니다." >&2
fi

exit 0
