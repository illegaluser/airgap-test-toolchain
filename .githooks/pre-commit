#!/usr/bin/env bash
# pre-commit hook — auto-run Recording UI / Auth Profile E2E
#
# Skips when staged files do not touch recording_service / auth_profiles / E2E tests.
# Skips (does not block the developer) when the venv python is missing or a port is in use.
#
# Install: run `playwright-allinone/scripts/install-git-hooks.sh` once.
# Temporary bypass: `git commit --no-verify` (emergency hotfixes only).
#
# Suites (triggered based on the changed area):
#   1) test_recording_ui_e2e.py            (port 18093) — Recording UI regression
#   2) test_auth_profile_api_e2e.py        (port 18094) — Auth Profile HTTP API
#   3) test_auth_profile_ui_e2e.py         (port 18095) — Auth Profile UI

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT/playwright-allinone"

# 1. Change-area filter — skip when UI / Auth Profile / E2E / dependent backend code is not touched.
#    Also triggers on auth_profiles / executor / __main__ changes.
RELEVANT_PATTERN='^playwright-allinone/(recording_service/|zero_touch_qa/(auth_profiles|executor|__main__)\.py|test/(test_recording_(ui_e2e|service)|test_auth_profile_(api|ui)_e2e|test_auth_(profiles|cli)|test_post_process|test_replay_proxy_auth|test_executor_fingerprint_env|test_visibility_healer.*)\.py|test/e2e_p1_auth_profiles\.py)'
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)
if ! echo "$CHANGED" | grep -qE "$RELEVANT_PATTERN"; then
  echo "[pre-commit] no changes in Recording UI / Auth Profile / dependent areas — skipping E2E"
  exit 0
fi

# 2. venv python check — warn and skip when missing instead of blocking the developer.
VENV_PY="${E2E_PYTHON:-$HOME/.dscore.ttc.playwright-agent/venv/bin/python3}"
if [ ! -x "$VENV_PY" ]; then
  echo "[pre-commit] ⚠ venv python missing — skipping E2E ($VENV_PY)"
  echo "  Setup: create the venv via mac-agent-setup.sh / wsl-agent-setup.sh"
  exit 0
fi

# 3. Port-conflict detection — the 3 suites use 18093/18094/18095.
for PORT in 18093 18094 18095; do
  if command -v lsof >/dev/null 2>&1 && lsof -i :$PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
    echo "[pre-commit] ⚠ port $PORT in use — skipping E2E"
    echo "  Holding process: $(lsof -i :$PORT -sTCP:LISTEN -t | head -1)"
    exit 0
  fi
done

# 4. Run E2E. Block the commit on regression.
#    AUTH_PROFILE_VERIFY_HEADLESS=1 — run the verify step headless (friendly to CI/headless envs).
#    The production default is headed (D9 — fingerprint stability). Override only inside this hook.
echo "[pre-commit] running E2E suites (3 of them, ports 18093/18094/18095, headless chromium)..."
START=$(date +%s)
RC=0
for TEST_FILE in \
  test/test_recording_ui_e2e.py \
  test/test_auth_profile_api_e2e.py \
  test/test_auth_profile_ui_e2e.py
do
  echo "[pre-commit] → $TEST_FILE"
  PYTHONPATH=. AUTH_PROFILE_VERIFY_HEADLESS=1 "$VENV_PY" -m pytest \
      "$TEST_FILE" -q --tb=short -p no:cacheprovider || {
    RC=$?
    break
  }
done
ELAPSED=$(( $(date +%s) - START ))

if [ $RC -ne 0 ]; then
  echo ""
  echo "[pre-commit] ✗ E2E failed (${ELAPSED}s) — commit blocked"
  echo "  Bypass: git commit --no-verify (emergencies only)"
  exit $RC
fi

echo "[pre-commit] ✓ E2E passed (${ELAPSED}s)"
exit 0
