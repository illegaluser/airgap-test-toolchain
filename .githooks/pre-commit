#!/usr/bin/env bash
# pre-commit hook — A 그룹 emit/generator unit 슈트.
#
# 설계 근거: playwright-allinone/docs/PLAN_E2E_REWRITE.md §4 (4슬롯 구조)
#   - 시간 예산: < 30s
#   - 외부 의존 0 (브라우저/daemon 없음, AST/string emit 결정론)
#   - 통합 E2E 는 pre-push 로 이동
#
# 설치: bash playwright-allinone/scripts/install-git-hooks.sh
# 우회: git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
UNIT_DIR="$REPO_ROOT/playwright-allinone/e2e-test/unit"
VENV_PY="${E2E_PYTHON:-$HOME/.dscore.ttc.playwright-agent/venv/bin/python3}"

if [ ! -d "$UNIT_DIR" ]; then
  echo "[pre-commit] ⚠ e2e-test/unit/ 미존재 — 스킵 (rollback 또는 다른 브랜치)"
  exit 0
fi
if [ ! -x "$VENV_PY" ]; then
  echo "[pre-commit] ⚠ venv python 미존재 — unit 슈트 스킵 ($VENV_PY)"
  echo "  설정: mac-agent-setup.sh / wsl-agent-setup.sh 로 venv 생성"
  exit 0
fi

cd "$REPO_ROOT/playwright-allinone"
echo "[pre-commit] e2e-test/unit/ 발사..."
START=$(date +%s)

if "$VENV_PY" -m pytest e2e-test/unit -q --tb=short; then
  ELAPSED=$(( $(date +%s) - START ))
  echo "[pre-commit] ✓ e2e-test/unit/ 통과 (${ELAPSED}s)"
  exit 0
else
  RC=$?
  ELAPSED=$(( $(date +%s) - START ))
  echo ""
  echo "[pre-commit] ✗ e2e-test/unit/ 실패 (${ELAPSED}s) — commit 차단"
  echo "  우회: git commit --no-verify (긴급시만)"
  exit $RC
fi
