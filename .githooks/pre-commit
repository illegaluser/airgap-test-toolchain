#!/usr/bin/env bash
# pre-commit hook — playwright-allinone 통합 E2E 자동 실행
#
# 통합 E2E 슈트(`pytest -m e2e`) 한 번에 모든 영역을 검증한다. 슈트 구성은
# `playwright-allinone/test/E2E_COVERAGE.md` 참조.
#
# 변경된 파일이 recording_service / auth_profiles / discover / e2e test 와
# 무관하면 skip. venv python 미존재 / 포트 충돌 감지 후 skip (개발자 차단 회피).
#
# 설치: `playwright-allinone/scripts/install-git-hooks.sh` 한 번 실행.
# 일시 우회: `git commit --no-verify` (긴급 핫픽스용).
#
# 사용 포트: 18093 (Recording UI) · 18094 (Auth Profile API) ·
#           18095 (Auth Profile UI) · 18096 (Discover URLs API)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT/playwright-allinone"

# 1. 변경 영역 필터 — 무관한 변경이면 e2e 생략.
RELEVANT_PATTERN='^playwright-allinone/(recording_service/|zero_touch_qa/(auth_profiles|executor|__main__|url_discovery)\.py|test/(test_recording_(ui_e2e|service)|test_auth_profile_(api|ui)_e2e|test_auth_(profiles|cli)|test_post_process|test_replay_proxy_auth|test_executor_fingerprint_env|test_visibility_healer.*|test_discover_api_e2e|test_url_discovery)\.py|test/e2e_p1_auth_profiles\.py)'
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)
if ! echo "$CHANGED" | grep -qE "$RELEVANT_PATTERN"; then
  echo "[pre-commit] 무관한 변경 — 통합 E2E 스킵"
  exit 0
fi

# 2. venv python 확인 — 미설치 시 차단하지 않고 경고 후 skip.
VENV_PY="${E2E_PYTHON:-$HOME/.dscore.ttc.playwright-agent/venv/bin/python3}"
if [ ! -x "$VENV_PY" ]; then
  echo "[pre-commit] ⚠ venv python 미존재 — E2E 스킵 ($VENV_PY)"
  echo "  설정: mac-agent-setup.sh / wsl-agent-setup.sh 로 venv 생성"
  exit 0
fi

# 3. 포트 충돌 감지 — 슈트가 4개 포트(18093~18096)를 사용한다.
for PORT in 18093 18094 18095 18096; do
  if command -v lsof >/dev/null 2>&1 && lsof -i :$PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
    echo "[pre-commit] ⚠ port $PORT 점유 중 — E2E 스킵"
    echo "  점유 프로세스: $(lsof -i :$PORT -sTCP:LISTEN -t | head -1)"
    exit 0
  fi
done

# 4. 통합 E2E 실행. 회귀 시 commit 차단.
#    AUTH_PROFILE_VERIFY_HEADLESS=1 — verify 단계 headless (CI/headless 환경 친화).
#    운영 기본은 headed (D9 — fingerprint 안정성). 본 hook 안에서만 한정 override.
echo "[pre-commit] 통합 E2E 실행 (pytest -m e2e, headless chromium)..."
START=$(date +%s)
PYTHONPATH=. AUTH_PROFILE_VERIFY_HEADLESS=1 "$VENV_PY" -m pytest \
    test -m e2e -q --tb=short -p no:cacheprovider
RC=$?
ELAPSED=$(( $(date +%s) - START ))

if [ $RC -ne 0 ]; then
  echo ""
  echo "[pre-commit] ✗ 통합 E2E 실패 (${ELAPSED}s) — commit 차단"
  echo "  우회: git commit --no-verify (긴급시만)"
  exit $RC
fi

echo "[pre-commit] ✓ 통합 E2E 통과 (${ELAPSED}s)"
exit 0
