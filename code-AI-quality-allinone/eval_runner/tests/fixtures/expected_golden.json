    {"criteria": "응답에 부산이 포함되어야 합니다", "actual_output": "서울입니다.", "expected": false},
    {"criteria": "응답에 김철수가 포함되어야 함", "actual_output": "당신의 이름은 김철수 입니다", "expected": true},
    {"criteria": "response must include 'Seoul'", "actual_output": "The capital is Seoul.", "expected": true},
    {"criteria": "자유 서술형 평가 기준", "actual_output": "아무 내용", "expected": null},
    {"criteria": "", "actual_output": "내용", "expected": null}
