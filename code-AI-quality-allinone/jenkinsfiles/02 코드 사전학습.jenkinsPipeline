pipeline {
    agent any
    
    parameters {
        string(name: 'REPO_URL', defaultValue: 'http://gitlab:80/root/realworld.git', description: 'Git 레포지토리 URL (예: http://gitlab:80/root/realworld.git)')
        booleanParam(name: 'ENRICH_CONTEXT', defaultValue: true, description: 'Contextual Retrieval (gemma4 청크 요약 prepend) 적용 여부. false 시 skip.')
        // Phase 1.5: 체인 Job 이 전달. 빈 값이면 HEAD 자동 해석 (수동 실행 하위호환).
        string(name: 'COMMIT_SHA', defaultValue: '', description: '특정 커밋 SHA 지정 (체인 Job 용). 빈 값이면 레포 HEAD 사용.')
        choice(name: 'ANALYSIS_MODE', choices: ['full', 'commit'], description: 'KB manifest 기록용 메타 — full: 전수 재빌드, commit: 해당 SHA 스냅샷')
        string(name: 'BRANCH', defaultValue: 'main', description: 'kb_manifest 기록용 브랜치 (실제 clone 대상과 독립)')
    }
    
    environment {
        SCRIPTS_DIR = '/var/jenkins_home/scripts'
        WORKSPACE_CODES = '/var/knowledges/codes'
        RESULT_DIR = '/var/knowledges/docs/result'
        DOC_FORM = 'text_model'
        DOC_LANGUAGE = 'Korean'
        // 통합 이미지 내부 Dify API / Ollama 주소. 스크립트 env override 로 사용.
        DIFY_API_BASE = 'http://127.0.0.1:5001/v1'
        OLLAMA_API_URL = 'http://host.docker.internal:11434/api/generate'
        // P1.5 — Pre-training Report. publishHTML 대상.
        REPORT_DIR = "${WORKSPACE}/pretraining-report"
        REPORT_FILE = 'pretraining-report.html'
    }

    stages {
        stage('1. Git Clone') {
            when { expression { params.REPO_URL != '' } }
            steps {
                echo "[Clone] Git 레포지토리 클론 시작: ${params.REPO_URL}"
                script {
                    env.REPO_NAME = sh(script: "basename '${params.REPO_URL}' .git", returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'gitlab-pat', variable: 'GITLAB_PAT')]) {
                    sh """
                    set -e
                    # REPO_URL 에 oauth2:${GITLAB_PAT}@ 주입. public/private 모두 작동.
                    AUTH_URL=\$(printf '%s' '${params.REPO_URL}' | sed -E "s|^(https?)://|\\\\1://oauth2:\${GITLAB_PAT}@|")
                    # 기존 코드 디렉터리 초기화
                    rm -rf '${env.WORKSPACE_CODES}'/*
                    # Git 클론 (실제 저장소 이름으로 디렉터리 생성)
                    git clone "\$AUTH_URL" '${env.WORKSPACE_CODES}/${env.REPO_NAME}'
                    echo "[Clone] 완료"
                    """
                }
            }
        }
        
        stage('2. Build Context (AST chunks)') {
            steps {
                script {
                    if (!env.REPO_NAME?.trim()) {
                        env.REPO_NAME = sh(script: "basename '${params.REPO_URL}' .git", returnStdout: true).trim()
                    }
                    // Phase 1.5: params.COMMIT_SHA override 우선, 없으면 HEAD 자동 해석.
                    def shaOverride = (params.COMMIT_SHA ?: '').trim()
                    if (shaOverride) {
                        env.COMMIT_SHA = shaOverride
                    } else {
                        env.COMMIT_SHA = sh(
                            script: "cd ${env.WORKSPACE_CODES}/${env.REPO_NAME} 2>/dev/null && git rev-parse HEAD 2>/dev/null || echo ''",
                            returnStdout: true
                        ).trim()
                    }
                    echo "[Build] commit=${env.COMMIT_SHA?.take(8) ?: '(none)'} mode=${params.ANALYSIS_MODE}"
                }
                echo "[Build] tree-sitter AST 청킹 시작"
                sh """
                set -e
                # 이전 결과물(JSONL/MD) 완전 제거 후 새로 생성 — Dify 중복 upload 방지
                rm -rf '${env.RESULT_DIR}'/* 2>/dev/null || true
                # P1.5 — Pre-training Report 출력 디렉터리 준비
                mkdir -p '${env.REPORT_DIR}'

                python3 '${env.SCRIPTS_DIR}/repo_context_builder.py' \
                    --repo_root '${env.WORKSPACE_CODES}/${env.REPO_NAME}' \
                    --out '${env.RESULT_DIR}' \
                    --commit-sha '${env.COMMIT_SHA}' \
                    --report-html '${env.REPORT_DIR}/${env.REPORT_FILE}'

                JSONL_COUNT=\$(ls '${env.RESULT_DIR}'/*.jsonl 2>/dev/null | wc -l)
                CHUNK_COUNT=\$(cat '${env.RESULT_DIR}'/*.jsonl 2>/dev/null | wc -l)
                echo "[Build] JSONL 파일 \${JSONL_COUNT} 개, 총 청크 \${CHUNK_COUNT} 개"
                echo "[Build] Pre-training Report: ${env.REPORT_DIR}/${env.REPORT_FILE}"
                """
            }
        }

        stage('2.5 Contextual Enrichment (optional)') {
            when { expression { params.ENRICH_CONTEXT != 'false' } }
            steps {
                echo "[Enrich] Contextual Retrieval 요약 생성 — gemma4:e4b"
                sh '''
                set -e
                # 실패해도 파이프라인 통과 (graceful). 요약 없이 원본 청크 유지.
                python3 ${SCRIPTS_DIR}/contextual_enricher.py --in ${RESULT_DIR} || \
                    echo "[Enrich:WARN] enricher 일부 실패 — 원본 청크로 계속"
                '''
            }
        }

        stage('3. Upload Context') {
            steps {
                withCredentials([
                    string(credentialsId: 'dify-knowledge-key', variable: 'DIFY_API_KEY'),
                    string(credentialsId: 'dify-dataset-id', variable: 'DIFY_DATASET_ID')
                ]) {
                    echo "[Upload] JSONL 청크 → Dify Dataset (high_quality 모드)"
                    // Dify 1.13.3 의 알려진 SQLAlchemy bug — dataset 의 hit_count
                    // property 가 cache_key 생성 중 'async for' mismatch 를 일으켜
                    // 첫 청크 SUCCESS 후 후속 호출이 모두 HTTP 500 으로 깨질 수
                    // 있다 (dify-api.log 에 'TypeError: async for requires...').
                    // 회복: dify-api 재시작 → SQLAlchemy session pool 초기화.
                    // 이 stage 는 1차 시도 실패 시 자동으로 재시작 + 1회 재시도.
                    sh """
                    set -e
                    export KB_MANIFEST_REPO_URL='${params.REPO_URL}'
                    export KB_MANIFEST_BRANCH='${params.BRANCH}'
                    KB_MANIFEST_COMMIT_SHA='${env.COMMIT_SHA}'
                    KB_MANIFEST_ANALYSIS_MODE='${params.ANALYSIS_MODE}'
                    [ -n "\${KB_MANIFEST_ANALYSIS_MODE}" ] || KB_MANIFEST_ANALYSIS_MODE="full"
                    export KB_MANIFEST_COMMIT_SHA KB_MANIFEST_ANALYSIS_MODE

                    UPLOAD_LOG=\$(mktemp)
                    # Fix A — full 모드에서는 Dataset 기존 문서 전수 삭제 후 upload.
                    # 이전 프로젝트/이전 실행의 잔재 청크가 retrieve 결과에 섞여
                    # citation rate 가 급락하는 문제 방지 (관측 2.1%).
                    PURGE_FLAG=""
                    if [ "\${KB_MANIFEST_ANALYSIS_MODE}" = "full" ]; then
                        PURGE_FLAG="--purge"
                    fi
                    run_upload() {
                        python3 '${env.SCRIPTS_DIR}/doc_processor.py' upload \
                            "\$DIFY_API_KEY" \
                            "\$DIFY_DATASET_ID" \
                            '${env.DOC_FORM}' \
                            '${env.DOC_LANGUAGE}' \
                            \$PURGE_FLAG 2>&1 | tee "\$UPLOAD_LOG"
                    }

                    # 1차 시도
                    run_upload || true

                    # FAIL 라인이 있으면 dify-api 재시작 + 재시도 (Dify 1.13.3 bug 회복).
                    # SUCCESS 라인 단 1개 + FAIL 다수 패턴 검출.
                    FAIL_COUNT=\$(grep -c '\\[Upload:FAIL\\]' "\$UPLOAD_LOG" || true)
                    SUCC_COUNT=\$(grep -c '\\[Upload:SUCCESS\\]' "\$UPLOAD_LOG" || true)
                    if [ "\${FAIL_COUNT:-0}" -gt 0 ]; then
                        echo "[Upload:RECOVER] FAIL=\${FAIL_COUNT} SUCCESS=\${SUCC_COUNT} — Dify 1.13.3 SQLAlchemy bug 가능성. dify-api 재시작 후 재시도."
                        supervisorctl -c /etc/supervisor/supervisord.conf restart dify-api >/dev/null 2>&1 || true
                        # dify-api 재기동 health 대기 (최대 60s)
                        _w=0
                        until curl -sf -o /dev/null --max-time 3 http://127.0.0.1:5001/console/api/setup; do
                            sleep 2; _w=\$((_w+2))
                            [ \$_w -ge 60 ] && { echo "[Upload:RECOVER] dify-api 60s 내 미준비"; break; }
                        done
                        echo "[Upload:RECOVER] dify-api ready (\${_w}s) — 재시도"
                        run_upload
                        # 2차도 FAIL 이면 stage 실패 처리
                        FAIL2=\$(grep -c '\\[Upload:FAIL\\]' "\$UPLOAD_LOG" || true)
                        if [ "\${FAIL2:-0}" -gt 0 ]; then
                            echo "[Upload:FAIL] 재시도 후에도 FAIL=\${FAIL2} — 수동 점검 필요 (README §12 참조)"
                            rm -f "\$UPLOAD_LOG"
                            exit 1
                        fi
                    fi
                    rm -f "\$UPLOAD_LOG"
                    echo "[Upload] 완료"
                    """
                }
            }
        }

        stage('4. Wait for Dify Indexing') {
            // Dify 의 document indexing (bge-m3 embedding + Qdrant 색인) 은
            // 업로드 후 async 로 진행된다. P1 이 업로드 완료 직후 SUCCESS 로
            // 마감되면 뒤따르는 P3 의 knowledge-retrieval 이 빈 결과를 돌려받아
            // LLM 입력의 RAG 컨텍스트가 통째로 비는 race condition 이 발생한다.
            // → 본 스테이지는 모든 문서의 indexing_status = completed 가 될 때
            //   까지 polling 하여 체인의 다음 단계로 넘어가기 전에 KB 가 실제
            //   검색 가능한 상태임을 보장한다.
            steps {
                withCredentials([
                    string(credentialsId: 'dify-knowledge-key', variable: 'DIFY_API_KEY'),
                    string(credentialsId: 'dify-dataset-id', variable: 'DIFY_DATASET_ID')
                ]) {
                    sh '''
                    set -e
                    # --timeout 0 = 무한 대기. 사용 이유:
                    #   realworld 같은 ~400 청크 레포는 bge-m3 임베딩 + Dify indexing 이
                    #   30분 초과 가능 (관측: 387 청크 → 14~25분). 30분 hard cap 으로
                    #   끊으면 KB 가 partial 상태로 남고 03/04 가 빈 RAG 로 실행되어
                    #   재실행 비용이 더 큼. 03/04 의 RAG 빈 답변 비용 > 무한 대기 위험.
                    #   Dify 가 진짜 hang 되면 호출 측에서 Jenkins UI 로 abort 가능.
                    python3 "${SCRIPTS_DIR}/dify_kb_wait_indexed.py" \
                        --dify-api-base "${DIFY_API_BASE}" \
                        --dataset-id "${DIFY_DATASET_ID}" \
                        --api-key "${DIFY_API_KEY}" \
                        --timeout 0 \
                        --interval 10
                    '''
                }
            }
        }
    }
    
    post {
        always {
            // P1.5 — Pre-training Report (publishHTML).
            // Stage 2 가 실패해도 일부 리포트가 남을 수 있도록 always 블록에서 시도.
            // 리포트 파일이 없으면 placeholder 를 생성해 "왜 비었는지" 안내 (05 AI평가
            // 와 동일 패턴). allowMissing=false 를 강제해 Jenkins 가 누락 자체를
            // 실패 신호로 집계한다.
            script {
                sh """
                mkdir -p '${env.REPORT_DIR}'
                if [ ! -f '${env.REPORT_DIR}/${env.REPORT_FILE}' ]; then
                    cat > '${env.REPORT_DIR}/${env.REPORT_FILE}' <<HTMLEOF
<!DOCTYPE html><html lang="ko"><head><meta charset="utf-8">
<title>Pre-training Report (empty)</title></head><body>
<h1>Pre-training Report — 데이터 없음</h1>
<p>이 빌드에서 리포트 파일이 생성되지 않았습니다. 아래를 확인하세요:</p>
<ul>
<li>Stage 1 (Git Clone) 이 끝까지 성공했는지 — REPO_URL / gitlab-pat 자격</li>
<li>Stage 2 (Build Context) 의 repo_context_builder.py 로그</li>
<li>대상 레포에 tree-sitter 지원 언어 (.py/.java/.ts/.tsx/.js) 파일이 있는지</li>
</ul>
<p>Console Output 과 <em>Artifacts</em> 에서 로그를 먼저 확인하세요.</p>
</body></html>
HTMLEOF
                fi
                """
                try {
                    publishHTML(
                        target: [
                            reportName: 'Pre-training Report',
                            reportDir: env.REPORT_DIR,
                            reportFiles: env.REPORT_FILE,
                            keepAll: true,
                            alwaysLinkToLastBuild: true,
                            allowMissing: false
                        ]
                    )
                } catch (ignored) {
                    echo "publishHTML plugin unavailable — 리포트는 Artifacts 로만 접근 가능."
                }
                archiveArtifacts artifacts: "pretraining-report/${env.REPORT_FILE}", allowEmptyArchive: true
            }
        }
        success {
            echo "[Success] 코드 지식화 작업이 성공적으로 완료되었습니다."
        }
        failure {
            echo "[Failure] 작업 중 오류가 발생했습니다. 로그를 확인하세요."
        }
    }
}
