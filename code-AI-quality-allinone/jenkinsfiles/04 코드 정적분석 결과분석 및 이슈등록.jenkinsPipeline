pipeline {
  agent any

  parameters {
    string(name: 'SONAR_PROJECT_KEY', defaultValue: 'nodegoat', description: 'SonarQube Project Key')
    string(name: 'SEVERITIES', defaultValue: 'BLOCKER,CRITICAL,MAJOR,MINOR,INFO', description: 'Sonar severities. 기본값은 모든 severity 포함')
    string(name: 'STATUSES', defaultValue: 'OPEN,REOPENED,CONFIRMED', description: 'Sonar statuses. 기본값은 미해결 상태 전체')
    string(name: 'MAX_ISSUES', defaultValue: '0', description: 'Dify에 보낼 이슈 건수. 0=전체')
    string(name: 'GITLAB_PROJECT', defaultValue: 'root/nodegoat', description: 'GitLab project path (예: group/project)')
    string(name: 'BRANCH', defaultValue: 'main', description: 'Git 브랜치 (commit SHA 해석 + GitLab blob/commit URL 구성)')
    // GitLab Issue 본문 내 외부 링크용 — 사용자 브라우저가 실제 접근할 주소.
    // 기본값은 docker-compose 호스트 포트 매핑. 운영 환경에 맞게 override.
    string(name: 'SONAR_PUBLIC_URL',  defaultValue: 'http://localhost:29000', description: 'GitLab Issue 본문에 렌더링될 SonarQube 외부 URL')
    string(name: 'GITLAB_PUBLIC_URL', defaultValue: 'http://localhost:28090', description: 'GitLab Issue 본문의 blob/commit 링크에 쓸 GitLab 외부 URL')

    // Phase 1.5: 체인 Job 전파 파라미터. 빈 COMMIT_SHA → 단독 실행 흐름 (git ls-remote 로 해석).
    string(name: 'COMMIT_SHA', defaultValue: '', description: '특정 커밋 SHA (체인 Job 전달). 빈 값이면 BRANCH HEAD 자동 해석.')
    choice(name: 'ANALYSIS_MODE', choices: ['full', 'commit'], description: 'full: KB freshness assert skip | commit: kb_manifest.commit_sha 불일치 시 fail')
    choice(name: 'MODE', choices: ['full', 'incremental'], description: 'exporter diff-mode — full: last_scan.json 리셋 후 전수, incremental: last_scan 차이분만 emit')
  }

  environment {
    // 통합 all-in-one 이미지 내부: SonarQube · Dify API 모두 localhost 포트.
    // (Dify gateway nginx 는 28081 이지만 console/v1 API 는 5001 direct.)
    SONAR_HOST_URL  = 'http://127.0.0.1:9000'
    DIFY_API_BASE   = 'http://127.0.0.1:5001/v1'
    GITLAB_HOST_URL = 'http://gitlab:80'
    SCRIPTS_DIR     = '/var/jenkins_home/scripts'
    // GitLab PAT — provision.sh 가 런타임에 credentials('gitlab-pat') 으로 치환
    GITLAB_PAT      = ''
  }

  stages {
    // Phase 1.5: 체인 Job 이 params.COMMIT_SHA 를 전달하면 ls-remote 해석 skip.
    // 빈 값이면 기존 단독 실행 경로 (git ls-remote 로 BRANCH HEAD 해석). 이어서
    // enclosing_function 추출용으로 /var/knowledges/codes 아래 얕게 clone/fetch.
    // ANALYSIS_MODE=commit 경우 /data/kb_manifest.json 의 commit_sha 와 일치 확인
    // (freshness assert) — 불일치 시 fail.
    stage('(0) Resolve Commit SHA + Fetch Repo') {
      steps {
        withCredentials([string(credentialsId: 'gitlab-pat', variable: 'GITLAB_PAT')]) {
          script {
            def sha = (params.COMMIT_SHA ?: '').trim()
            if (!sha) {
              sha = sh(
                script: "git ls-remote http://oauth2:\${GITLAB_PAT}@gitlab:80/${params.GITLAB_PROJECT}.git refs/heads/${params.BRANCH} | head -1 | awk '{print \$1}'",
                returnStdout: true
              ).trim()
              echo "[Resolve] COMMIT_SHA not provided — resolved via ls-remote: ${sha}"
            } else {
              echo "[Resolve] COMMIT_SHA from chain Job: ${sha}"
            }
            if (!sha) {
              error "commit SHA 해석 실패 — GITLAB_PROJECT / BRANCH 확인"
            }
            env.COMMIT_SHA = sha

            if (params.ANALYSIS_MODE == 'commit') {
              def check = sh(
                script: '''
                    if [ ! -f /data/kb_manifest.json ]; then
                        echo "MISSING"
                        exit 0
                    fi
                    python3 -c "import json;print(json.load(open('/data/kb_manifest.json')).get('commit_sha',''))" 2>/dev/null || echo ""
                ''',
                returnStdout: true
              ).trim()
              if (check == 'MISSING') {
                error "[Freshness] /data/kb_manifest.json 부재 — ANALYSIS_MODE=commit 은 P1 을 먼저 돌리거나 체인 Job 경유 실행 필요"
              } else if (check != sha) {
                error "[Freshness] kb_manifest.commit_sha=${check} 이 요청 COMMIT_SHA=${sha} 와 불일치 — P1 재실행 필요"
              } else {
                echo "[Freshness] KB manifest 일치 (${check})"
              }
            } else {
              echo "[Freshness] mode=full — assert skip"
            }
          }
          sh """
            set -e
            REPO_NAME=\$(basename "${params.GITLAB_PROJECT}")
            REPO_ROOT="/var/knowledges/codes/\${REPO_NAME}"
            # 레포가 없거나 현재 HEAD 가 commit_sha 와 다르면 얕게 clone/fetch.
            # enclosing_function 추출용 — P1 이 이미 clone 해 두었으면 재사용.
            if [ ! -d "\${REPO_ROOT}/.git" ]; then
                mkdir -p "\$(dirname \${REPO_ROOT})"
                rm -rf "\${REPO_ROOT}"
                git clone --depth 50 --branch "${params.BRANCH}" \\
                    "http://oauth2:\${GITLAB_PAT}@gitlab:80/${params.GITLAB_PROJECT}.git" \\
                    "\${REPO_ROOT}"
            else
                (cd "\${REPO_ROOT}" && git fetch --depth 50 origin "${params.BRANCH}" && git checkout -f "origin/${params.BRANCH}")
            fi
            # COMMIT_SHA 가 명시되면 해당 커밋으로 체크아웃 (git_context/enclosing 용).
            if [ -n "${env.COMMIT_SHA ?: ''}" ]; then
                (cd "\${REPO_ROOT}" && git checkout -f "${env.COMMIT_SHA ?: ''}" 2>/dev/null) || \\
                    echo "[Resolve:WARN] ${env.COMMIT_SHA ?: ''} checkout 실패 — shallow clone 깊이 초과 가능. 기본 HEAD 사용."
            fi
            echo "[Resolve] repo_root=\${REPO_ROOT}"
          """
        }
      }
    }

    stage('(1) Export Sonar Issues') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
          sh """
            set -e
            REPO_NAME=\$(basename "${params.GITLAB_PROJECT}")
            python3 ${SCRIPTS_DIR}/sonar_issue_exporter.py \
              --sonar-host-url "${SONAR_HOST_URL}" \
              --sonar-token "${SONAR_TOKEN}" \
              --project-key "${params.SONAR_PROJECT_KEY}" \
              --severities "${params.SEVERITIES}" \
              --statuses "${params.STATUSES}" \
              --commit-sha "${env.COMMIT_SHA}" \
              --repo-root "/var/knowledges/codes/\${REPO_NAME}" \
              --disable-clustering \
              --mode "${params.MODE}" \
              --state-dir "/var/knowledges/state" \
              --callgraph-dir "/var/knowledges/docs/result" \
              --output "sonar_issues.json"
          """
        }
      }
    }

    stage('(2) Analyze by Dify Workflow') {
      steps {
        withCredentials([string(credentialsId: 'dify-workflow-key', variable: 'DIFY_API_KEY')]) {
          sh """
            set -e
            python3 ${SCRIPTS_DIR}/dify_sonar_issue_analyzer.py \
              --dify-api-base "${DIFY_API_BASE}" \
              --dify-api-key "${DIFY_API_KEY}" \
              --input "sonar_issues.json" \
              --output "llm_analysis.jsonl" \
              --user "jenkins" \
              --response-mode "blocking" \
              --timeout 1000 \
              --max-issues ${params.MAX_ISSUES} \
              --commit-sha "${env.COMMIT_SHA}" \
              --hyde-ollama-base-url "http://host.docker.internal:11434" \
              --hyde-ollama-model "gemma4:e4b" \
              --print-first-errors 5
          """
        }
      }
    }

    stage('(3) Create GitLab Issues (Dedup)') {
      steps {
        // Step D — sonarqube-token + gitlab-pat 을 withCredentials 로 한 번에 바인딩.
        // provision.sh 의 sed 치환 (`GITLAB_PAT = credentials('gitlab-pat')`) 은
        // declarative environment{} 블록에서 동작하지만 Groovy `${GITLAB_PAT}` 바인딩이
        // 로컬 sh 블록에서 해석되지 않는 경우가 있어 명시적으로 credential 주입.
        withCredentials([
          string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN_PRIVATE'),
          string(credentialsId: 'gitlab-pat',     variable: 'GITLAB_PAT_LOCAL')
        ]) {
          sh """
            set -e
            set +x
            python3 ${SCRIPTS_DIR}/gitlab_issue_creator.py \
              --gitlab-host-url "${GITLAB_HOST_URL}" \
              --gitlab-token "\${GITLAB_PAT_LOCAL}" \
              --gitlab-project "${params.GITLAB_PROJECT}" \
              --gitlab-public-url "${params.GITLAB_PUBLIC_URL}" \
              --gitlab-branch "${params.BRANCH}" \
              --commit-sha "${env.COMMIT_SHA}" \
              --input "llm_analysis.jsonl" \
              --output "gitlab_issues_created.json" \
              --sonar-host-url "${SONAR_HOST_URL}" \
              --sonar-public-url "${params.SONAR_PUBLIC_URL}" \
              --sonar-token "\${SONAR_TOKEN_PRIVATE}" \
              --analysis-mode "${params.ANALYSIS_MODE}"
          """
        }
      }
    }
  }

  post {
    always {
      // P1.5 M-1~M-4 — per-이슈 RAG 진단 리포트 (publishHTML 탭).
      // llm_analysis.jsonl 의 rag_diagnostic 필드를 집계해 이슈 분석 품질 지표 렌더.
      // 리포트 파일이 없으면 placeholder 로 탭에 "왜 비었는지" 안내.
      script {
        sh '''
        mkdir -p diagnostic-report
        if [ -f llm_analysis.jsonl ]; then
          python3 "${SCRIPTS_DIR}/diagnostic_report_builder.py" \
            --input llm_analysis.jsonl \
            --output diagnostic-report/diagnostic-report.html \
            || echo "[Diag] report builder 실패 — placeholder 생성"
        fi
        if [ ! -f diagnostic-report/diagnostic-report.html ]; then
          cat > diagnostic-report/diagnostic-report.html <<HTMLEOF
<!DOCTYPE html><html lang="ko"><head><meta charset="utf-8">
<title>RAG Diagnostic Report (empty)</title></head><body>
<h1>RAG Diagnostic Report — 데이터 없음</h1>
<p>이 빌드에서 <code>llm_analysis.jsonl</code> 이 생성되지 않았거나
diagnostic_report_builder 가 실패했습니다. 아래를 확인하세요:</p>
<ul>
<li>Stage (1) Export 가 0 건이면 분석할 이슈 자체가 없습니다 (Sonar 이슈 0건)</li>
<li>Stage (2) Analyze 의 Dify 호출 로그 — 네트워크/PAT 오류</li>
<li>Stage (2) 의 rag_diagnostic 은 context_filter/json_parser Code 노드가
필요합니다. workflow 이 구버전이면 dify 를 재provision 하세요.</li>
</ul></body></html>
HTMLEOF
        fi
        '''
        try {
          publishHTML(
            target: [
              reportName: 'RAG Diagnostic Report',
              reportDir: 'diagnostic-report',
              reportFiles: 'diagnostic-report.html',
              keepAll: true,
              alwaysLinkToLastBuild: true,
              allowMissing: false
            ]
          )
        } catch (ignored) {
          echo 'publishHTML plugin unavailable — 리포트는 Artifacts 로만 접근 가능.'
        }
      }
      archiveArtifacts artifacts: 'sonar_issues.json,llm_analysis.jsonl,gitlab_issues_created.json,diagnostic-report/diagnostic-report.html', fingerprint: true, allowEmptyArchive: true
    }
  }
}
