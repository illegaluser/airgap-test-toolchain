pipeline {
    agent any
    environment {
        LANGFUSE_HOST = 'http://host.docker.internal:3000'
        PYTHONPATH = '/var/jenkins_home/scripts/eval_runner'
        REPORT_ROOT_DIR = '/var/knowledges/eval/reports'
        REPORT_DIR = "${REPORT_ROOT_DIR}/build-${BUILD_NUMBER}"
    }
    stages {
        stage('1. 시험지(Golden Dataset) 준비') {
            steps {
                script {
                    sh """
                    mkdir -p "\$(dirname '${params.GOLDEN_CSV_PATH}')"
                    mkdir -p '${env.REPORT_ROOT_DIR}'
                    mkdir -p '${env.REPORT_DIR}'
                    """
                    if (params.UPLOADED_GOLDEN_DATASET?.trim()) {
                        sh """
                        cp "${env.UPLOADED_GOLDEN_DATASET}" "${params.GOLDEN_CSV_PATH}"
                        """
                        echo "Uploaded dataset has been copied to ${params.GOLDEN_CSV_PATH}"
                    } else {
                        echo "Using existing dataset at ${params.GOLDEN_CSV_PATH}"
                    }
                }
            }
        }
        stage('1-1. Judge / Target Model preflight 검증') {
            steps {
                withEnv([
                    "OLLAMA_BASE_URL=${params.OLLAMA_BASE_URL}",
                    "JUDGE_MODEL=${params.JUDGE_MODEL ?: ''}",
                    "TARGET_OLLAMA_MODEL=${params.TARGET_OLLAMA_MODEL ?: ''}",
                    "TARGET_TYPE=${params.TARGET_TYPE ?: 'local_ollama_wrapper'}",
                ]) {
                    sh '''
                    set -eu
                    # JUDGE_MODEL + (local_ollama_wrapper 모드일 때) TARGET_OLLAMA_MODEL 둘 다
                    # 호스트 Ollama /api/tags 에 실제 등록돼 있는지 먼저 검증합니다.
                    # 누락 시 즉시 fail — 평가 단계까지 가서 어댑터가 HTTP 404 로 깨지는 낭비를
                    # 막는 게 목적입니다 (CascadeChoice fallback 이 호스트에 없는 모델을 default
                    # 로 줄 수 있는 윈도우 차단).
                    NORMALIZED_OLLAMA_BASE_URL="$(printf '%s' "$OLLAMA_BASE_URL" | sed 's:/*$::')"
                    TAGS_URL="$NORMALIZED_OLLAMA_BASE_URL/api/tags"
                    TMP_JSON="$(mktemp)"
                    EFFECTIVE_MODEL_FILE=".effective_judge_model"
                    trap 'rm -f "$TMP_JSON"' EXIT

                    curl -fsSL "$TAGS_URL" -o "$TMP_JSON"

                    echo "--------------------------------------------------"
                    echo "Installed Ollama models:"
                    python3 - "$TMP_JSON" "${JUDGE_MODEL:-}" "${TARGET_OLLAMA_MODEL:-}" "${TARGET_TYPE:-}" "$EFFECTIVE_MODEL_FILE" <<'PY'
import json
import sys

payload_path, judge_model, target_model, target_type, output_path = (
    sys.argv[1], sys.argv[2].strip(), sys.argv[3].strip(), sys.argv[4].strip(), sys.argv[5]
)
with open(payload_path, "r", encoding="utf-8") as fh:
    payload = json.load(fh) or {}

models = sorted({model.get("name") for model in payload.get("models", []) if model.get("name")})
for model in models:
    print(f" - {model}")

if not models:
    raise SystemExit("No Ollama models were returned from /api/tags.")

# JUDGE_MODEL: 항상 검증 (모든 TARGET_TYPE 에서 심판으로 사용)
if judge_model:
    if judge_model not in models:
        raise SystemExit(
            f"Selected JUDGE_MODEL '{judge_model}' is not installed on host Ollama. "
            f"Choose one of: {', '.join(models)}"
        )
    effective_judge = judge_model
else:
    preferred = ["qwen3-coder:30b", "qwen2:7b"]
    effective_judge = next((m for m in preferred if m in models), models[0])
    print(f"JUDGE_MODEL was empty. Auto-selected installed model: {effective_judge}")

# TARGET_OLLAMA_MODEL: local_ollama_wrapper 모드일 때만 검증
# (http / ui_chat 모드에서는 외부 어댑터를 쓰므로 이 필드가 의미 없음)
if target_type == "local_ollama_wrapper":
    if target_model:
        if target_model not in models:
            raise SystemExit(
                f"Selected TARGET_OLLAMA_MODEL '{target_model}' is not installed on host Ollama. "
                f"TARGET_TYPE=local_ollama_wrapper 모드에서는 호스트에 실재하는 모델만 선택 가능합니다. "
                f"Choose one of: {', '.join(models)}"
            )
        print(f"Selected target model confirmed: {target_model}")
    else:
        print("TARGET_OLLAMA_MODEL was empty (will default to JUDGE_MODEL in wrapper).")

with open(output_path, "w", encoding="utf-8") as fh:
    fh.write(effective_judge)

print("--------------------------------------------------")
print(f"Selected judge model confirmed: {effective_judge}")
PY
                    '''
                }
            }
        }
        stage('1-2. 로컬 Ollama Wrapper 기동 + 연결 검증') {
            when {
                // Phase 6: local_ollama_wrapper 모드에서만 wrapper 를 기동한다.
                // http / ui_chat 모드는 외부/다른 어댑터를 쓰므로 wrapper 를 띄우지 않는다.
                expression { (params.TARGET_TYPE ?: 'local_ollama_wrapper') == 'local_ollama_wrapper' }
            }
            steps {
                withEnv([
                    "OLLAMA_BASE_URL=${params.OLLAMA_BASE_URL}",
                    "JUDGE_MODEL=${params.JUDGE_MODEL ?: ''}",
                    "TARGET_OLLAMA_MODEL=${params.TARGET_OLLAMA_MODEL ?: ''}",
                    "REPORT_DIR=${env.REPORT_DIR}",
                ]) {
                    sh '''
                    set +x
                    set -eu
                    WRAPPER_PID_FILE=".wrapper_pid"
                    EFFECTIVE_TARGET_URL_FILE=".effective_target_url"
                    rm -f "$EFFECTIVE_TARGET_URL_FILE"

                    # 평가 대상 모델 (wrapper 가 답변자로 사용). TARGET_OLLAMA_MODEL 이 없으면
                    # JUDGE_MODEL 로 fallback (자기평가). Phase 6 에서 분리.
                    EFFECTIVE_TARGET_MODEL="${TARGET_OLLAMA_MODEL:-}"
                    if [ -z "$EFFECTIVE_TARGET_MODEL" ]; then
                        EFFECTIVE_TARGET_MODEL="${JUDGE_MODEL:-}"
                        if [ -f .effective_judge_model ]; then
                            EFFECTIVE_TARGET_MODEL="$(cat .effective_judge_model)"
                        fi
                    fi
                    if [ -z "$EFFECTIVE_TARGET_MODEL" ]; then
                        echo "Cannot start wrapper: both TARGET_OLLAMA_MODEL and JUDGE_MODEL are empty."
                        exit 2
                    fi
                    echo "$EFFECTIVE_TARGET_MODEL" > .effective_target_model
                    echo "Wrapper target model: $EFFECTIVE_TARGET_MODEL"

                    # 이전 빌드의 wrapper 프로세스 잔재 정리
                    if [ -f "$WRAPPER_PID_FILE" ]; then
                        OLD_PID="$(cat "$WRAPPER_PID_FILE" || true)"
                        if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
                            kill "$OLD_PID" 2>/dev/null || true
                            sleep 1
                            kill -9 "$OLD_PID" 2>/dev/null || true
                        fi
                        rm -f "$WRAPPER_PID_FILE"
                    fi

                    echo "Auto-managing local Ollama wrapper"
                    nohup env \
                        OLLAMA_WRAPPER_HOST=0.0.0.0 \
                        OLLAMA_WRAPPER_PORT=8000 \
                        OLLAMA_BASE_URL="$OLLAMA_BASE_URL" \
                        OLLAMA_MODEL="$EFFECTIVE_TARGET_MODEL" \
                        python3 /var/jenkins_home/scripts/eval_runner/ollama_wrapper_api.py \
                        > "$REPORT_DIR/wrapper.log" 2>&1 &
                    WRAPPER_PID="$!"
                    echo "$WRAPPER_PID" > "$WRAPPER_PID_FILE"

                    READY="false"
                    for _ in $(seq 1 20); do
                        if curl -fsS http://127.0.0.1:8000/health >/dev/null 2>&1; then
                            READY="true"
                            break
                        fi
                        sleep 1
                    done

                    if [ "$READY" != "true" ]; then
                        echo "Wrapper startup failed. See $REPORT_DIR/wrapper.log"
                        tail -n 100 "$REPORT_DIR/wrapper.log" || true
                        exit 1
                    fi

                    EFFECTIVE_TARGET_URL="http://127.0.0.1:8000/invoke"
                    echo "Wrapper started (pid=$WRAPPER_PID), effective TARGET_URL=$EFFECTIVE_TARGET_URL"
                    echo "$EFFECTIVE_TARGET_URL" > "$EFFECTIVE_TARGET_URL_FILE"

                    # 평가 시작 전 local wrapper 엔드포인트(health + invoke) 가용성 사전 검증
                    export EFFECTIVE_TARGET_URL
                    python3 - <<'PY'
import os
import socket
from urllib.parse import urlparse

import requests

target_url = os.environ.get("EFFECTIVE_TARGET_URL", "").strip()
if not target_url:
    raise SystemExit("EFFECTIVE_TARGET_URL is empty.")

parsed = urlparse(target_url)
host = parsed.hostname or ""
port = parsed.port or (443 if parsed.scheme == "https" else 80)
if not host:
    raise SystemExit(f"Invalid TARGET_URL: {target_url}")

# IPv4/IPv6 중 어떤 주소가 실패해도 원인을 분명히 보여주기 위한 주소별 TCP probe.
addr_results = []
tcp_reachable = False
for family, socktype, proto, _, sockaddr in socket.getaddrinfo(host, port, 0, socket.SOCK_STREAM):
    sock = socket.socket(family, socktype, proto)
    sock.settimeout(2)
    try:
        sock.connect(sockaddr)
        addr_results.append(f"OK   {sockaddr}")
        tcp_reachable = True
    except OSError as exc:
        addr_results.append(f"FAIL {sockaddr} -> {exc}")
    finally:
        sock.close()

print("Address connectivity details:")
for row in addr_results:
    print(f" - {row}")

if not tcp_reachable:
    raise SystemExit(
        "Cannot reach local wrapper endpoint.\\n"
        f" - EFFECTIVE_TARGET_URL: {target_url}\\n"
        f" - host: {host}, port: {port}\\n"
        "Wrapper startup appears to have succeeded health loop but TCP is now unreachable."
    )

try:
    # wrapper health 확인 → invoke probe 로 Ollama upstream 가용성까지 확인
    parsed_health = urlparse(target_url)
    health_url = f"{parsed_health.scheme}://{parsed_health.netloc}/health"
    health_response = requests.get(health_url, timeout=5)
    print(f"Wrapper health probe response: HTTP {health_response.status_code}")
    if health_response.status_code >= 400:
        compact_body = " ".join((health_response.text or "").split())
        raise SystemExit(
            f"local_ollama_wrapper health probe failed with HTTP {health_response.status_code}. "
            f"body={compact_body[:500]}"
        )
except requests.RequestException as exc:
    raise SystemExit(f"Wrapper endpoint TCP reachable, but /health probe failed: {exc}")

# 첫 invoke 는 Ollama 가 모델을 RAM/VRAM 에 로드하는 시간을 포함. 로컬 LLM (>=4B) 은
# cold-start 시 수 분 이상 걸릴 수 있으며, 모델이 이전 빌드와 다르면 GPU 에서 교체
# 로드가 필요하다. probe 실패는 FATAL 로 올리지 말고 경고만 남기고 진행 —
# Stage 2 의 pytest 가 동일 wrapper 를 호출하므로 거기서 실 error 로 수집된다.
try:
    response = requests.post(target_url, json={"input": "ping"}, timeout=300)
    print(f"Wrapper invoke probe response: HTTP {response.status_code}")
    if response.status_code >= 400:
        compact_body = " ".join((response.text or "").split())
        print(
            f"WARN: invoke probe returned HTTP {response.status_code} "
            f"(body={compact_body[:200]}) — continuing; pytest will surface if real issue."
        )
except requests.RequestException as exc:
    print(f"WARN: invoke probe failed: {exc}. Continuing to pytest (cold-start timeout)")

# Phase 6: Judge 모델도 본 pytest 전에 한 번 VRAM 에 올려둔다 (warm-up).
# 이렇게 하지 않으면 첫 케이스의 첫 Judge 호출 시 TARGET 모델과 동시 상주가 안 돼 swap
# 이 발생 → Ollama 가 매 호출마다 모델을 내렸다 다시 올려 60~120 초 지연이 반복된다.
# 호스트 Ollama 의 `OLLAMA_MAX_LOADED_MODELS=2` 이상 권장 (없으면 swap 지속).
import os as _os
_ollama_base = _os.environ.get("OLLAMA_BASE_URL", "http://host.docker.internal:11434").rstrip("/")
_judge_model = _os.environ.get("JUDGE_MODEL", "").strip()
if _judge_model:
    try:
        _r = requests.post(
            f"{_ollama_base}/api/generate",
            json={"model": _judge_model, "prompt": "ping", "stream": False,
                  "options": {"num_predict": 4}, "keep_alive": "10m"},
            timeout=300,
        )
        print(f"Judge warm-up ({_judge_model}): HTTP {_r.status_code}")
    except requests.RequestException as exc:
        print(f"WARN: Judge warm-up failed: {exc}. pytest 가 cold-start 겪을 수 있음.")
PY
                    '''
                }
            }
        }
        stage('2. 파이썬 평가 실행 (Pytest)') {
            steps {
                script {
                    // Langfuse 유무와 무관하게 동일한 평가 명령을 재사용하기 위한 클로저입니다.
                    def runEval = { ->
                        // Phase 6: TARGET_TYPE 에 따라 어댑터 선택 + env 분기
                        def targetType = params.TARGET_TYPE ?: 'local_ollama_wrapper'
                        // local_ollama_wrapper → http_adapter + wrapper URL (127.0.0.1:8000/invoke)
                        // http                 → http_adapter + 사용자 TARGET_URL
                        // ui_chat              → browser_adapter + 사용자 TARGET_URL
                        def adapterKind = (targetType == 'ui_chat') ? 'ui_chat' : 'http'
                        def requestSchema = params.TARGET_REQUEST_SCHEMA ?: 'standard'
                        sh """
                        set +x
                        echo "=================================================="
                        echo "             STARTING EVALUATION RUN              "
                        echo "=================================================="
                        echo "TARGET_TYPE: ${targetType} (adapter=${adapterKind})"
                        EFFECTIVE_TARGET_URL=""
                        if [ "${targetType}" = "local_ollama_wrapper" ]; then
                          if [ -f .effective_target_url ]; then
                            EFFECTIVE_TARGET_URL="\$(cat .effective_target_url)"
                          fi
                          if [ -z "\$EFFECTIVE_TARGET_URL" ]; then
                            echo "Effective target URL missing — Stage 1-2 did not run?"
                            exit 2
                          fi
                        else
                          EFFECTIVE_TARGET_URL="${params.TARGET_URL}"
                          if [ -z "\$EFFECTIVE_TARGET_URL" ]; then
                            echo "TARGET_URL is required when TARGET_TYPE=${targetType}"
                            exit 2
                          fi
                        fi
                        echo "TARGET_URL: \$EFFECTIVE_TARGET_URL"
                        EFFECTIVE_JUDGE_MODEL="${params.JUDGE_MODEL ?: ''}"
                        if [ -f .effective_judge_model ]; then
                          EFFECTIVE_JUDGE_MODEL="\$(cat .effective_judge_model)"
                        fi
                        if [ -z "\$EFFECTIVE_JUDGE_MODEL" ]; then
                          echo "JUDGE_MODEL is empty and no auto-selected model was found."
                          exit 2
                        fi
                        echo "JUDGE_MODEL: \$EFFECTIVE_JUDGE_MODEL"
                        echo "OLLAMA_BASE_URL: ${params.OLLAMA_BASE_URL}"
                        echo "TARGET_REQUEST_SCHEMA: ${requestSchema}"
                        echo "ANSWER_RELEVANCY_THRESHOLD: ${params.ANSWER_RELEVANCY_THRESHOLD}"
                        echo "GOLDEN_CSV_PATH: ${params.GOLDEN_CSV_PATH}"
                        echo "REPORT_DIR: ${env.REPORT_DIR}"
                        echo "--------------------------------------------------"
                        export TARGET_URL="\$EFFECTIVE_TARGET_URL"
                        export TARGET_TYPE='${adapterKind}'
                        export TARGET_REQUEST_SCHEMA='${requestSchema}'
                        # TARGET_AUTH_HEADER 는 Password 파라미터로 받아 워크스페이스 로그에 노출되지 않도록 env 에만 주입.
                        export TARGET_AUTH_HEADER='${params.TARGET_AUTH_HEADER ?: ''}'
                        export UI_INPUT_SELECTOR='${params.UI_INPUT_SELECTOR ?: ''}'
                        export UI_SEND_SELECTOR='${params.UI_SEND_SELECTOR ?: ''}'
                        export UI_OUTPUT_SELECTOR='${params.UI_OUTPUT_SELECTOR ?: ''}'
                        export UI_WAIT_TIMEOUT='${params.UI_WAIT_TIMEOUT ?: '60'}'
                        # adapter HTTP timeout. 기본 300s. 로컬 Ollama 가 모델 swap 중이면 더 필요할 수 있음.
                        export ADAPTER_TIMEOUT_SEC="${env.ADAPTER_TIMEOUT_SEC ?: '300'}"
                        export JUDGE_MODEL="\$EFFECTIVE_JUDGE_MODEL"
                        export OLLAMA_BASE_URL='${params.OLLAMA_BASE_URL}'
                        export ANSWER_RELEVANCY_THRESHOLD='${params.ANSWER_RELEVANCY_THRESHOLD}'
                        export GOLDEN_CSV_PATH='${params.GOLDEN_CSV_PATH}'
                        export REPORT_DIR='${env.REPORT_DIR}'
                        export PYTHONPATH='${env.PYTHONPATH}'
                        set -x

                        # Phase 6: pytest 실시간 진행 노출
                        #  - xdist(-n 1) 제거: 단일 worker 로 쓸 때 출력을 버퍼링해 Jenkins 콘솔에서
                        #    모든 case 가 끝날 때까지 진행을 전혀 볼 수 없었다.
                        #  - PYTHONUNBUFFERED=1 + python3 -u: stdout/stderr 라인 버퍼 무효화.
                        #  - -v / --tb=short: 각 케이스 시작·종료 라인이 즉시 한 줄씩 찍힌다.
                        #  - -s (capture=no): test_runner 내부 print(연결/LLM 호출 등) 도 즉시 flush.
                        PYTHONUNBUFFERED=1 python3 -u -m pytest /var/jenkins_home/scripts/eval_runner/tests/test_runner.py \
                          -v -s --tb=short \
                          --junitxml=${env.REPORT_DIR}/results.xml
                        """
                    }

                    try {
                        withCredentials([
                            string(credentialsId: 'langfuse-public-key', variable: 'LANGFUSE_PUBLIC_KEY'),
                            string(credentialsId: 'langfuse-secret-key', variable: 'LANGFUSE_SECRET_KEY')
                        ]) {
                            runEval()
                        }
                    } catch (err) {
                        echo "Langfuse credentials not found or unavailable. Continuing evaluation without Langfuse tracing."
                        withEnv(['LANGFUSE_PUBLIC_KEY=', 'LANGFUSE_SECRET_KEY=']) {
                            runEval()
                        }
                    }
                }
            }
        }
    }
    post {
        always {
            script {
                // 자동 기동한 wrapper 프로세스가 남지 않도록 항상 종료를 시도합니다.
                sh '''
                if [ -f .wrapper_pid ]; then
                    WRAPPER_PID="$(cat .wrapper_pid || true)"
                    if [ -n "${WRAPPER_PID:-}" ] && kill -0 "$WRAPPER_PID" 2>/dev/null; then
                        kill "$WRAPPER_PID" 2>/dev/null || true
                        sleep 1
                        kill -9 "$WRAPPER_PID" 2>/dev/null || true
                    fi
                    rm -f .wrapper_pid
                fi
                rm -f .effective_target_url .effective_judge_model
                '''

                // 실행 단계에서 이미 REPORT_DIR=.../build-<번호>로 저장되므로,
                // 아티팩트만 워크스페이스로 복사해 보존합니다.
                def buildFolder = "build-${env.BUILD_NUMBER ?: 'manual'}"
                def artifactDir = "eval-reports/${buildFolder}"
                sh """
                mkdir -p '${artifactDir}'
                find '${env.REPORT_DIR}' -maxdepth 1 -type f -exec cp -f {} '${artifactDir}/' \\;
                """
                // junit step 은 JUnit plugin 의존. 플러그인 미설치 에어갭 환경에서 post always 를
                // 깨뜨리지 않도록 try/catch 로 감싼다. 결과는 results.xml 아카이브로 대체 노출.
                try {
                    junit testResults: "${artifactDir}/results.xml", allowEmptyResults: true
                } catch (NoSuchMethodError e) {
                    echo "junit DSL unavailable (JUnit plugin missing) — skipping results aggregation; results.xml 은 archiveArtifacts 로 보존"
                }
                archiveArtifacts artifacts: "${artifactDir}/*", allowEmptyArchive: true

                def safeBuildTag = (env.BUILD_TAG ?: env.BUILD_ID ?: 'manual').replaceAll('[^a-zA-Z0-9_.-]', '')
                def publicLangfuseUrl = "${env.LANGFUSE_HOST}/project/traces?filter=tags%3D${safeBuildTag}"
                def summaryUrl = env.BUILD_URL ? "${env.BUILD_URL}artifact/${artifactDir}/summary.html" : "${artifactDir}/summary.html"
                echo "Evaluation summary: ${summaryUrl}"
                echo "Evaluation raw json: ${env.BUILD_URL ?: ''}artifact/${artifactDir}/summary.json"
                echo "Report build folder: ${env.REPORT_DIR}"

                // Phase 2.6 R6 — summary.html 이 missing 이면 명시적 placeholder 를 생성해
                // 탭 접근 시 "왜 빈지" 이유를 보여준다. publishHTML 은 allowMissing=false 로
                // 강제해 Jenkins 가 누락 자체를 실패로 집계하게 함.
                sh """
                if [ ! -f '${artifactDir}/summary.html' ]; then
                    cat > '${artifactDir}/summary.html' <<HTMLEOF
<!DOCTYPE html><html lang="ko"><head><meta charset="utf-8">
<title>AI Eval Summary (empty)</title></head><body>
<h1>AI Eval Summary — 데이터 없음</h1>
<p>이 빌드에서 <code>summary.html</code> 이 생성되지 않았습니다.
아래를 확인하세요:</p>
<ul>
<li>Stage 1-2 의 Ollama wrapper 기동 로그</li>
<li>Stage 2 의 pytest 종료 코드 + <code>results.xml</code></li>
<li>REPORT_DIR(<code>${env.REPORT_DIR}</code>) 내 artifacts</li>
</ul>
<p>Jenkins 빌드 페이지의 <em>Console Output</em> 과 아래 <em>Artifacts</em> 를
먼저 확인하세요.</p></body></html>
HTMLEOF
                fi
                """

                try {
                    publishHTML(
                        target: [
                            reportName: "AI Eval Summary (${buildFolder})",
                            reportDir: artifactDir,
                            reportFiles: 'summary.html',
                            keepAll: true,
                            alwaysLinkToLastBuild: true,
                            allowMissing: false
                        ]
                    )
                } catch (ignored) {
                    echo "publishHTML plugin is unavailable. Open summary via Artifacts."
                }

                // Build 화면 description에 직접 링크를 남깁니다.
                // (Markup Formatter 설정에 따라 HTML이 비활성화된 경우 URL 텍스트로 fallback)
                def summaryLinkHtml = "<a href='${summaryUrl}'>summary.html</a>"
                def langfuseLinkHtml = "<a href='${publicLangfuseUrl}'>langfuse</a>"
                try {
                    currentBuild.description = "Summary: ${summaryLinkHtml} | Langfuse: ${langfuseLinkHtml}"
                } catch (ignored) {
                    currentBuild.description = "Summary: ${summaryUrl} | Langfuse: ${publicLangfuseUrl}"
                }
            }
        }
    }
